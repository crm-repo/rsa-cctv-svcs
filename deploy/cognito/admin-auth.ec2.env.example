# RSA CMS Batch 40/41 Admin Auth EC2 environment example
# Do not commit a real backend.env with secrets.
# Batch 40 keeps admin blocked publicly while Cognito is prepared.

# Current safe default until Batch 41 enables Cognito-protected admin access.
RSA_ADMIN_AUTH_MODE=disabled

# Set these only after the Cognito user pool and app client are created.
RSA_COGNITO_REGION=ap-southeast-1
RSA_COGNITO_USER_POOL_ID=
RSA_COGNITO_APP_CLIENT_ID=

# Existing deployment runtime values shown for context.
RSA_ENV=ec2-demo
RSA_REPOSITORY_MODE=dynamodb
AWS_DEFAULT_REGION=ap-southeast-1
AWS_REGION=ap-southeast-1

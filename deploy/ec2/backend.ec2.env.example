# RSA CMS / Mini-CRM EC2 backend environment example
# Copy to /opt/rsa-cms/.env on EC2 and edit there.
# Do not commit a real .env file.

RSA_APP_ENV=ec2-demo
RSA_REPOSITORY_MODE=dynamodb
AWS_REGION=ap-southeast-1

# Admin auth remains disabled only for private/local testing.
# Do not expose admin publicly with auth disabled.
RSA_ADMIN_AUTH_MODE=disabled

# Notifications disabled by default to avoid SMS/email costs.
RSA_ENABLE_BOOKING_NOTIFICATIONS=false
RSA_ENABLE_INQUIRY_NOTIFICATIONS=false

# Media storage prep.
# Real S3 upload/storage should be enabled later only after S3 batch approval.
RSA_MEDIA_STORAGE_MODE=local-preview
RSA_UPLOAD_BINARY_ENABLED=false

# CORS:
# For first IP-based testing, set this to the exact frontend/admin origin once known.
# Example:
# RSA_CORS_ORIGINS=http://<EC2_PUBLIC_IP>,http://<EC2_PUBLIC_IP>:5500
RSA_CORS_ORIGINS=http://127.0.0.1:5500,http://localhost:5500

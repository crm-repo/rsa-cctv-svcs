[Unit]
Description=RSA CMS FastAPI Backend
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=ubuntu
Group=ubuntu
WorkingDirectory=/opt/rsa-cms/current/backend
EnvironmentFile=/opt/rsa-cms/runtime/backend.env
ExecStart=/opt/rsa-cms/venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
